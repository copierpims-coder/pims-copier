{
  "manifest_version": 3,
  "name": "PracticeHub → PIMS Copier",
  "version": "1.4.0",
  "description": "One-click copy of prescription data from Chewy PracticeHub to your PIMS clipboard.",
  "permissions": [
    "storage",
    "clipboardWrite",
    "activeTab"
  ],
  "host_permissions": [
    "https://*.chewyhealth.com/*",
    "https://*.practicehub.chewy.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.chewyhealth.com/*",
        "https://*.practicehub.chewy.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
